# OS / editor cruft
.DS_Store

# Python
__pycache__/
*.pyc

# Environments & secrets -- never commit
.env
*.env
*.pem
*.key
gpomol/

# Cluster / Dask runtime logs
scheduler_file*.json
dask_worker_info.txt
dask_launch.log
dask-worker-space/

# Data too large for GitHub (all regenerable)
train_4M/
*.aselmdb*
*.pkl

# Large numpy arrays anywhere -- but KEEP the small cache/ files the figures use
# (sweep_*.npz, subset_indices_*.npy, y_residual_*.npy, mean_model_*.npz)
*.npy
*.npz
!cache/*.npy
!cache/*.npz

# ...except the materialised dataset cache, which lives in cache/ but is huge
cache/materialized_*.pkl

# Legacy experiment/plot output (regenerable) -- keeps `git status` clean. New
# figures elsewhere (root, diagnostics/) stay trackable.
gp/**/*.png
gp/*.png
scripts/**/*.png
scripts/*.png
descriptor_eval/**/*.png
